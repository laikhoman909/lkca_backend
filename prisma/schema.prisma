// Prisma Schema for NestJS Backend API
// This schema defines the database models for User and Product entities


generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}


// User model with authentication and role-based access
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // Hashed password using bcrypt
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


  // Relations
  products  Product[]

}


// Product model with full CRUD operations
model Product {
  id          String   @id @default(uuid())
  name        String
  description String
  price       Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt


  // Relations
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

}


// Enum for user roles - ADMIN and USER
enum UserRole {
  ADMIN
  USER
}


// ─────────────────────────────────────────────
// SHARED LOOKUP TABLE
// ─────────────────────────────────────────────

model KeyValue {
  id          Int      @id @default(autoincrement())
  group       String   @db.VarChar(100)   // e.g. "StatusCaDeb", "NamaJelasSesuaiKtp"
  label       String   @db.VarChar(100)   // e.g. "RO", "A/O", "SESUAI"
  Description String?  @db.VarChar(255)
  CustomValue String?  @db.VarChar(255)
  isPreset    Boolean  @default(false)    // true = seed data

  // Form0 direct FK back-references
  form0StatusCaDeb    Form0[] @relation("Form0StatusCaDeb")
  form0JenisPengajuan Form0[] @relation("Form0JenisPengajuan")

  // Form1/5/6 direct FK back-references
  form1Items Form1[] 
  form3Items Form3[] 
  form4Items Form4[] 
  form5Items Form5[] 
  form6Items Form6[] 

  @@unique([group, label, CustomValue])
  @@map("key_value")
}

model KeyList {
  id      Int     @id @default(autoincrement())
  key     String  @db.VarChar(100)
  data1   String? @db.VarChar(255)
  data2   String? @db.VarChar(255)
  data3   String? @db.VarChar(255)
  data4   String? @db.VarChar(255)
  form0Id Int?
  form2Id Int?
  form0   Form0?  @relation(fields: [form0Id], references: [id], onDelete: Cascade)
  form2   Form2?  @relation(fields: [form2Id], references: [form0Id], onDelete: Cascade)

  @@index([form0Id, form2Id])
  @@map("key_list")
}

// ─────────────────────────────────────────────
// FORM 0 - FORM REKOMENDASI CREDIT ANALYST
// ─────────────────────────────────────────────

model Form0 {
  id               Int       @id @default(autoincrement())
  TanggalTelepon   DateTime
  JamTelepon       String    @db.VarChar(10)
  Cabang           String    @db.VarChar(100)
  NamaCmo          String    @db.VarChar(255)
  FidCmo           Int
  NamaDebitur      String    @db.VarChar(255)
  NamaDealer       String    @db.VarChar(255)
  Msub             String    @db.VarChar(100)

  kendaraan        KeyList[]

  StatusCaDebId    Int?
  StatusCaDeb      KeyValue? @relation("Form0StatusCaDeb", fields: [StatusCaDebId], references: [id])

  JenisPengajuanId Int?
  JenisPengajuan   KeyValue? @relation("Form0JenisPengajuan", fields: [JenisPengajuanId], references: [id])

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("form0")
}

// ─────────────────────────────────────────────
// FORM 1 - KONFIRMASI LATAR BELAKANG DEBITUR
// ─────────────────────────────────────────────

model Form1 {
  form0Id       Int @id
  latarBelakang       KeyValue[]   
  SusunanPengurus Form1SusunanPengurus[]
  keterangan  String? @db.VarChar(100)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@map("form1")
}

model Form1SusunanPengurus {
  id          Int     @id @default(autoincrement())
  NamaJabatan String? @db.VarChar(255)
  BesarSaham  String? @db.VarChar(100)
  Persen      String? @db.VarChar(20)
  Hubungan    String? @db.VarChar(100)
  form1Id     Int
  form1       Form1   @relation(fields: [form1Id], references: [form0Id], onDelete: Cascade)

  @@index([form1Id])
  @@map("form1_susunan_pengurus")
}

// ─────────────────────────────────────────────
// FORM 2 - KONFIRMASI DATA YANG DISERAHKAN KE PETUGAS IT
// ─────────────────────────────────────────────

model Form2 {
  form0Id         Int @id
  foto            KeyList[]
  dokumen         DokumenPersyaratan[]
  
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@map("form2")
}

model DokumenPersyaratan {
  id                    Int       @id @default(autoincrement())
  jenis_dokumen         String?
  status_ada            Boolean  @default(false)  
  tipe_dokumen          String?
  keterangan            String?   @db.Text
  
  form2Id     Int
  form2       Form2   @relation(fields: [form2Id], references: [form0Id], onDelete: Cascade)

  @@map("dokumen_persyaratan")
}

// ─────────────────────────────────────────────
// FORM 3 - KONFIRMASI TANDA TANGAN KONTRAK
// ─────────────────────────────────────────────

model Form3 {
  form0Id         Int @id
  keyValues       KeyValue[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@map("form3")
}

// ─────────────────────────────────────────────
// FORM 4 - KONFIRMASI KRONOLOGIS TRANSAKSI
// ─────────────────────────────────────────────

model Form4 {
  form0Id         Int @id
  keyValues       KeyValue[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@map("form4")
}

// ─────────────────────────────────────────────
// FORM 5 - KONFIRMASI PRODUK, JENIS PEMBIAYAAN
// ─────────────────────────────────────────────

model Form5 {
  form0Id                Int @id
  keyValues              KeyValue[]
  HargaOtr               String?    @db.VarChar(100)
  BesarDownPayment       String?    @db.VarChar(100)
  NamaTeleponPenjual     String?    @db.VarChar(255)
  HasilKonfirmasiPenjual String?    @db.Text
  KapanMemilikiMobil     String?    @db.VarChar(100)
  BerapaHargaBeli        String?    @db.VarChar(100)
  BesarKebutuhanDana     String?    @db.VarChar(100)
  TujuanKebutuhanDana    String?    @db.VarChar(255)
  PosisiBpkb             String?    @db.VarChar(100)
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  @@map("form5")
}

// ─────────────────────────────────────────────
// FORM 6 - KONFIRMASI USAHA / PENDAPATAN
// ─────────────────────────────────────────────

model Form6 {
  form0Id                  Int @id
  keyValues                KeyValue[]
  NamaPerusahaan           String?    @db.VarChar(255)
  JenisUsaha               String?    @db.VarChar(255)
  AlamatUsahaKantor        String?    @db.VarChar(255)
  AlamatPool               String?    @db.VarChar(255)
  TeleponHpEmail           String?    @db.VarChar(100)
  UsahaPekerjaanSebelumnya String?    @db.VarChar(255)
  UraianUsaha1             String?    @db.Text
  UraianUsaha2             String?    @db.Text
  UraianUsaha3             String?    @db.Text
  ECallRekanan             String?    @db.Text
  ECallLainnya             String?    @db.Text
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt

  @@map("form6")
}

// ─────────────────────────────────────────────
// FORM 7 - PERHITUNGAN PENDAPATAN DEBITUR
// ─────────────────────────────────────────────

model Pendapatan {
  id      Int     @id @default(autoincrement())
  key     String  @db.VarChar(100)
  income1 Int
  income2 Int
  income3 Int
  total   Int

  form7Id Int
  form7   Form7  @relation(fields: [form7Id], references: [form0Id], onDelete: Cascade)
  
  @@map("pendapatan")
}

model Kewajiban {
  id      Int     @id @default(autoincrement())
  key     String  @db.VarChar(100)
  value   String  @db.VarChar(100)

  form7Id Int
  form7   Form7  @relation(fields: [form7Id], references: [form0Id], onDelete: Cascade)
  
  @@map("kewajiban")
}

model Form7 {
  form0Id         Int @id
  pendapatan      Pendapatan[]
  kewajiban       Kewajiban[]
  
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@map("form7")
}

// ─────────────────────────────────────────────
// FORM 8 - MUTASI REKENING TABUNGAN
// ─────────────────────────────────────────────

model Form8 {
  form0Id         Int @id
  bank            Bank[]
  laporanKeuangan LaporanKeuangan[]
  keterangan      String? @db.VarChar(100)

  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@map("form8")
}

model Bank {
  id                    Int       @id @default(autoincrement())
  keterangan            String? @db.VarChar(100)
  atasNama              String? @db.VarChar(100)    
  mutasi                Mutasi[]
  nama                  String? @db.VarChar(100) 
  radio                 String? @db.VarChar(20) 
  saldoAwal             Int
  
  form8Id Int
  form8   Form8  @relation(fields: [form8Id], references: [form0Id], onDelete: Cascade)

  @@map("bank")
}

model Mutasi {
  id                    Int       @id @default(autoincrement())
  keterangan            String? @db.VarChar(100)
  debit                 Int    
  kredit                Int
  saldo                 Int
  
  bankId     Int
  bank       Bank   @relation(fields: [bankId], references: [id], onDelete: Cascade)

  @@map("mutasi")
}

model LaporanKeuangan {
  id                    Int       @id @default(autoincrement())
  keterangan            String? @db.VarChar(100)
  pendapatanLaba        Int    
  biaya                 Int
  net                   Int
  
  form8Id     Int
  form8       Form8   @relation(fields: [form8Id], references: [form0Id], onDelete: Cascade)

  @@map("laporan_keuangan")
} 


// ─────────────────────────────────────────────
// FORM 9 - KONFIRMASI ASSETS LAIN YANG DIMILIKI
// ─────────────────────────────────────────────

model Form9 {
  form0Id         Int @id
  aset            Aset[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@map("form9")
}

model Aset {
  id                    Int       @id @default(autoincrement())
  merk_tipe_tahun       String?
  nopol                 String?
  status                String?
  nama_bank             String?
  
  form9Id     Int
  form9       Form9   @relation(fields: [form9Id], references: [form0Id], onDelete: Cascade)

  @@map("aset")
}

// ─────────────────────────────────────────────
// FORM 10 - KONFIRMASI ASSETS LAIN YANG DIMILIKI
// ─────────────────────────────────────────────